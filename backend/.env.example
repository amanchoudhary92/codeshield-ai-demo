# Server
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
FEEDBACK_FORM_URL=https://forms.gle/replace-with-your-form

# GitHub App credentials
# App ID is different from Client ID. Use App ID from GitHub App settings.
GITHUB_APP_ID=123456
GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nreplace\n-----END RSA PRIVATE KEY-----"
GITHUB_WEBHOOK_SECRET=replace_with_random_secret

# Optional local testing without GitHub signature verification
ALLOW_UNVERIFIED_WEBHOOKS=false

# Demo scan limits
MAX_FILES_PER_PR=40
MAX_PATCH_CHARS_PER_FILE=50000
MAX_FINDINGS_PER_PR=25
